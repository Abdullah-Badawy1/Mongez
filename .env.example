###############################################################################
# Mongez backend — environment variables
# Copy this file to `.env` and edit the values you need. The Docker stack
# loads `.env` automatically; the `runserver` flow falls back to safe
# defaults when a variable is missing.
###############################################################################

# ── Django core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2
DJANGO_TIME_ZONE=UTC

# ── CORS / CSRF ──────────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Pagination ───────────────────────────────────────────────────────────────
API_PAGE_SIZE=20

# ── Rate limiting (DRF throttles, format "<count>/<period>") ─────────────────
# period: second / minute / hour / day
THROTTLE_ANON=30/min
THROTTLE_USER=120/min
THROTTLE_AUTH=10/min
THROTTLE_ORDER=20/hour
THROTTLE_RATING=30/hour

# ── Paymob (commission payments) ─────────────────────────────────────────────
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=0
PAYMOB_HMAC_SECRET=
COMMISSION_AMOUNT=20

# ── Firebase Cloud Messaging (push notifications) ────────────────────────────
# Leave blank in dev — the backend will persist in-app rows but skip HTTP push.
FCM_SERVER_KEY=

# ── Database (Docker uses /app/data/db.sqlite3 inside the container) ─────────
# Override only if you swap to PostgreSQL (psycopg2-binary already installed).
# SQLITE_PATH=/app/data/db.sqlite3
